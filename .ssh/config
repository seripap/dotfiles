# ~/.ssh/config — symlinked from ~/dotfiles/.ssh/config by `make install`.
# Real hosts (IPs, usernames, anything machine-specific) go in ~/.ssh/config.local,
# which is gitignored. Same split as ~/.extra for the shell.

# Defaults for every host. Zed remote dev and `devbox` both inherit these.
Host *
  # Multiplex: one real TCP connection per host, reused for every new
  # terminal/task/channel. Zed opens many channels and relies on this so you
  # auth once. Also makes `devbox run ...` instant after the first connect.
  ControlMaster auto
  ControlPath ~/.ssh/cm-%C          # %C is a short hash — dodges macOS's 104-char socket-path limit
  ControlPersist 10m                # keep the master alive 10m after the last session closes

  # Survive laptop sleep and flaky wifi instead of dropping the session.
  ServerAliveInterval 30
  ServerAliveCountMax 6
  TCPKeepAlive yes

# ---- Your servers live here (gitignored) ----
# Example ~/.ssh/config.local:
#
#   Host devbox
#     HostName devbox.your-tailnet.ts.net   # Tailscale MagicDNS name (no port-forwarding)
#     User dan
#     ForwardAgent yes                       # remote git push uses your LOCAL key; nothing stored on the box
#
Include ~/.ssh/config.local
